{
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "target": "esnext",
    "module": "esnext",
    "lib": ["es2020"],
    "isolatedModules": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "sourceMap": true,
    "types": ["react", "react-native"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "app/**/*",
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "src/utils/ziwei/test.ts"
  ]
}
